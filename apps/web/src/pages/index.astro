---
import Layout from '../layouts/Layout.astro';
import InstallAppButton from '../components/InstallAppButton.tsx';
---

<Layout title="Ahorcado en familia">
  <main class="flex min-h-dvh flex-col items-center justify-center px-6 py-10 lg:py-16">
    <section class="flex w-full max-w-md flex-col items-center gap-8 text-center md:max-w-lg lg:max-w-xl">
      <div class="flex flex-col items-center gap-3">
        <span class="text-5xl" aria-hidden>🎮</span>
        <h1 class="text-4xl font-extrabold tracking-tight text-white md:text-5xl lg:text-6xl">
          Ahorcado en familia
        </h1>
        <p class="text-base text-slate-300">
          Crea una sala desde tu celular, comparte el código y compitan en
          tiempo real para ver quién adivina primero la palabra.
        </p>
      </div>

      <div class="flex w-full flex-col gap-3">
        <a
          href="/host"
          class="rounded-2xl bg-amber-400 px-5 py-4 text-lg font-semibold text-slate-950 shadow-md transition hover:bg-amber-300"
        >
          Crear partida
        </a>
        <a
          href="/join"
          class="rounded-2xl border border-white/15 bg-white/5 px-5 py-4 text-lg font-semibold text-white transition hover:bg-white/10"
        >
          Unirme con un código
        </a>
        <InstallAppButton client:idle />
      </div>

      <p class="text-xs text-slate-500">
        Cada jugador tiene 8 oportunidades por ronda. Gana quien adivine primero.
      </p>
    </section>
  </main>
</Layout>
