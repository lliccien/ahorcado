# Caddy como proxy reverso del stack:
#  - GET /api/*       → api:3000 (sin prefijo)
#  - * /socket.io/*   → api:3000 (incluye upgrade WebSocket)
#  - resto            → web:3000 (Astro SSR)
#
# Caddy es el único servicio que se expone en Dokploy. El navegador
# hace todo en el mismo origen, así no hay CORS y socket.io conecta
# por el mismo dominio que sirve la web.

:80 {
	encode zstd gzip

	# Endpoints HTTP del API: el cliente llama a /api/sessions/...
	# y Caddy lo reenvía como /sessions/... al backend.
	handle_path /api/* {
		reverse_proxy api:3000
	}

	# socket.io usa la ruta canónica /socket.io/ y necesita upgrade WS.
	# `reverse_proxy` lo soporta automáticamente.
	handle /socket.io/* {
		reverse_proxy api:3000
	}

	# Todo lo demás va al SSR de Astro.
	handle {
		reverse_proxy web:3000
	}
}
