# ==============================================
# MONOREPO ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env in the root of the project
# and fill in the values for your environment
#
# cp .env.example .env
# ==============================================

# ----------------------------------------------
# API (NestJS) Configuration
# ----------------------------------------------

# Application
NODE_ENV=development
API_PORT=3000

# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=astro
DB_PASSWORD=astro
DB_NAME=astro_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# CORS: separar múltiples orígenes con coma. Vacío = permitir todo (solo dev).
CORS_ORIGIN=http://localhost:4321

# Idioma por defecto del seed de palabras (es-419 = español de Latinoamérica)
WORDS_SEED_LOCALE=es-419

# JWT Configuration (uncomment when implementing authentication)
# JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
# JWT_EXPIRES_IN=1d

# CORS configuration (optional)
# CORS_ORIGIN=http://localhost:3001

# Logging (optional)
# LOG_LEVEL=debug

# ----------------------------------------------
# WEB (AstroJS) Configuration
# ----------------------------------------------

# API Configuration
PUBLIC_API_URL=http://localhost:3000

# AstroJS Port
WEB_PORT=4321

# Analytics (optional)
# PUBLIC_GA_ID=
# PUBLIC_GTM_ID=

# Feature Flags (optional)
# PUBLIC_ENABLE_ANALYTICS=false

# ----------------------------------------------
# Docker Configuration (optional)
# ----------------------------------------------

# Use these when running with docker-compose
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=nestjs_db
